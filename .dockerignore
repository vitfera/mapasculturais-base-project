# .dockerignore para Mapas Culturais Base Project
# Exclui arquivos desnecessários do contexto de build do Docker

# Docker data directories
docker-data
docker-data/*

# Git
.git
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*.yml

# Logs
*.log
logs/
dev/docker-data/logs/

# Dados de desenvolvimento
dev/docker-data/db-data/
dev/docker-data/private-files/
dev/docker-data/public-files/
dev/docker-data/saas-files/

# Node modules (se existir)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos temporários
*.tmp
*.temp
.cache/
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# Arquivos de configuração local
.env.local
.env.development
.env.test
.env.production

# Backups
*.backup
*.bak
*.sql.gz

# Certificados SSL (development)
*.pem
*.key
*.crt
*.csr

# Scripts de desenvolvimento
dev/
*.sh